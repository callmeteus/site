---
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import { site } from "../config/site";

interface Props {
    title?: string;
    description?: string;
    image?: string;
}

const { title, description, image } = Astro.props;
const pageTitle = title ? `${title} | ${site.name}` : undefined;
---

<!doctype html>
<html lang="en">
    <head>
        <SEO title={pageTitle} description={description} image={image} />
    </head>
    <body class="min-h-dvh flex flex-col bg-surface text-zinc-200">
        <header class="sticky top-0 z-50 border-b border-border bg-surface/80 backdrop-blur-xl">
            <nav
                class="mx-auto flex max-w-3xl items-center justify-between px-4 py-3 sm:px-6"
                style="padding-top: max(0.75rem, env(safe-area-inset-top));"
                aria-label="Main navigation"
            >
                <a
                    href="/"
                    class="font-display text-lg font-bold tracking-tight text-gradient"
                >
                    {site.name}
                </a>
                <div class="flex items-center gap-1 sm:gap-2">
                    <a
                        href="/"
                        class="min-h-11 min-w-11 inline-flex items-center justify-center rounded-lg px-3 text-sm font-medium text-muted transition-colors hover:bg-white/5 hover:text-white"
                    >
                        Home
                    </a>
                    <a
                        href="/blog"
                        class="min-h-11 min-w-11 inline-flex items-center justify-center rounded-lg px-3 text-sm font-medium text-muted transition-colors hover:bg-white/5 hover:text-white"
                    >
                        Blog
                    </a>
                </div>
            </nav>
        </header>
        <main class="flex-grow">
            <slot />
        </main>
        <footer class="border-t border-border py-8 text-center text-sm text-muted">
            <p>&copy; {new Date().getFullYear()} {site.name} · <a href={site.domain} class="hover:text-accent-cyan transition-colors">{site.domain.replace("https://", "")}</a></p>
        </footer>
    </body>
</html>
