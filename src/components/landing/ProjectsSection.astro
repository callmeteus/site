---
import type { Project } from "../../config/projects";
import { projects } from "../../config/projects";
import { ArrowUpRight } from "@lucide/astro";

interface Props {
    items?: Project[];
}

const { items = projects } = Astro.props;
---

{items.length > 0 && (
    <section class="scroll-reveal px-4 py-6 sm:px-6">
        <div class="mx-auto max-w-md md:max-w-lg">
            <h2 class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-muted">
                Projects
            </h2>
            <div class="stagger-links grid grid-cols-1 gap-3 md:grid-cols-2">
                {items.map((project) => (
                    <a
                        href={project.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="glass-card glass-card-interactive group flex min-h-[7rem] flex-col rounded-2xl p-4 hover:bg-white/[0.06] md:min-h-[8rem]"
                    >
                        <div class="mb-2 flex items-start justify-between gap-2">
                            <h3 class="font-display text-base font-bold text-zinc-100 transition-colors group-hover:text-accent-cyan sm:text-lg">
                                {project.title}
                            </h3>
                            <ArrowUpRight
                                size={16}
                                class="arrow-nudge shrink-0 text-muted"
                                aria-hidden="true"
                            />
                        </div>
                        <p class="mb-3 flex-1 text-sm leading-relaxed text-muted line-clamp-2">
                            {project.description}
                        </p>
                        <div class="flex flex-wrap gap-1.5">
                            {project.tags.map((tag) => (
                                <span class="rounded-md bg-white/5 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide text-zinc-400 transition-colors group-hover:bg-accent-violet/10 group-hover:text-zinc-300">
                                    {tag}
                                </span>
                            ))}
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </section>
)}
