---
import type { SiteLink } from "../config/links";
import BrandIcon from "./Icon.astro";
import LangBadge from "./LangBadge.astro";
import { ArrowUpRight } from "@lucide/astro";

interface Props {
    link: SiteLink;
}

const { link } = Astro.props;
---

<a
    href={link.href}
    class="glass-card group flex min-h-[3.75rem] w-full items-center gap-3 rounded-2xl px-3 py-3 transition-all duration-200 hover:border-accent-violet/30 hover:bg-white/[0.06] active:scale-[0.99] sm:gap-4 sm:px-4"
    target={link.external ? "_blank" : undefined}
    rel={link.external ? "noopener noreferrer" : undefined}
>
    <span
        class:list={[
            "flex h-10 w-10 shrink-0 items-center justify-center rounded-xl shadow-lg sm:h-11 sm:w-11",
            link.accentClass,
        ]}
    >
        <BrandIcon name={link.icon} size={20} class="shrink-0" />
    </span>
    <span class="min-w-0 flex-1 text-left">
        <span class="block truncate text-sm font-semibold text-zinc-100 sm:text-base">
            {link.label}
        </span>
        {link.description && (
            <span class="block truncate text-xs text-muted sm:text-sm">
                {link.description}
            </span>
        )}
    </span>
    <span class="flex shrink-0 items-center gap-2">
        <LangBadge languages={link.languages} />
        {link.external && (
            <ArrowUpRight
                size={16}
                class="text-muted opacity-0 transition-opacity group-hover:opacity-100 sm:opacity-60"
                aria-hidden="true"
            />
        )}
    </span>
</a>
