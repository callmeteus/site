---
import type { LinkLanguage } from "../config/links";
import { getFlagSvgUrl, getFlagLabel } from "../utils/flags";

interface Props {
    lang: LinkLanguage;
    size?: number;
    class?: string;
}

const { lang, size = 16, class: className = "" } = Astro.props;
---

<img
    src={getFlagSvgUrl(lang)}
    alt=""
    width={size}
    height={size}
    class:list={["inline-block shrink-0 rounded-sm object-contain", className]}
    loading="lazy"
    decoding="async"
    aria-hidden="true"
    title={getFlagLabel(lang)}
/>
