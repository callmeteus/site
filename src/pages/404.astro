---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found" description="Page not found.">
    <section class="flex min-h-[50vh] flex-col items-center justify-center px-4 py-16 text-center">
        <h1 class="font-display text-6xl font-bold text-gradient">404</h1>
        <p class="mt-4 text-muted">This page doesn't exist.</p>
        <a
            href="/"
            class="mt-8 inline-flex min-h-11 items-center rounded-xl bg-accent-violet px-6 font-semibold text-white transition-colors hover:bg-accent-violet/90"
        >
            Go home
        </a>
    </section>
</BaseLayout>
